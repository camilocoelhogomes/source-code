{
  "connections": {
    "github-this-repo": {
      "type": "github",
      "token": {
        "env": "GITHUB_TOKEN"
      },
      "orgs": [
        "camilocoelhogomes"
      ],
      "repos": [
        "camilocoelhogomes/source-*"
      ],
      "revisions": {
        "branches": [
          "main"
        ]
      }
    },
    "local-e2e-fixture": {
      "type": "git",
      "url": "file:///repos/*",
      "revisions": {
        "branches": [
          "main"
        ]
      }
    },
    "local-missing-volume": {
      "type": "git",
      "url": "file:///repos/__missing_e2e_volume__/*",
      "revisions": {
        "branches": [
          "main"
        ]
      }
    }
  }
}
