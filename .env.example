# Canonical environment names for local delivery (no real secrets).
# Copy to .env and fill values; never commit secrets.

# Config (T01/T02)
CONFIG_PATH=./examples/config.json
INDEX_WORKERS=2
QUERY_WORKERS=4
INDEX_CRON="0 2 * * *"
# Set GITHUB_TOKEN in the real .env when using github connections.
# E2E/CI may set E2E_GITHUB_TOKEN instead.
E2E_GITHUB_TOKEN=

# --- Host dev / e2e (docker-compose.dev.yml — infra only, app no .venv) ---
# Suba infra: podman compose -f docker-compose.dev.yml up -d
# App: python -m github_rag.delivery
# E2e: python -m github_rag.e2e  (sobe infra + app host + Robot, sem rebuild)
GITHUB_RAG_DEV_HOST=127.0.0.1
GITHUB_RAG_APP_ROOT=.
ZOEKT_INDEX_HOST=./.data/dev-zoekt-index

# Catalog / infra — localhost quando app roda no host (dev/e2e)
DATABASE_URL=postgresql+psycopg://github_rag:github_rag@127.0.0.1:5432/github_rag

# Exact code index (T10)
ZOEKT_URL=http://127.0.0.1:6070
ZOEKT_INDEX_DIR=./.data/dev-zoekt-index

# Vector store (T13)
QDRANT_URL=http://127.0.0.1:6333

# SLM / embeddings (T12/T13) — OpenAI-compatible
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
OPENAI_API_KEY=local
SLM_MODEL=qwen2.5-coder:3b
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768

# Surfaces (T18/T17/T19)
UI_HOST=127.0.0.1
UI_PORT=8080
MCP_PORT=8001
MCP_TRANSPORT=sse

# Host mounts for compose usuário (docker-compose.yml — app em container)
HOST_CONFIG=./examples/config.json
HOST_REPOS=./repos

# --- docker-compose.yml (app em container) — hostnames de rede compose ---
# DATABASE_URL=postgresql+psycopg://github_rag:github_rag@postgres:5432/github_rag
# ZOEKT_URL=http://zoekt:6070
# QDRANT_URL=http://qdrant:6333
# OPENAI_BASE_URL=http://slm:11434/v1
