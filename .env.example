# Canonical environment names for local delivery (no real secrets).
# Copy to .env and fill values; never commit secrets.

# Config (T01/T02)
CONFIG_PATH=/config/config.json
INDEX_WORKERS=2
QUERY_WORKERS=4
INDEX_CRON=0 2 * * *
# Set GITHUB_TOKEN in the real .env when using github connections.
# E2E/CI may set E2E_GITHUB_TOKEN instead; docker-compose.e2e.yml maps it to GITHUB_TOKEN.
E2E_GITHUB_TOKEN=

# Catalog / infra (T03)
DATABASE_URL=postgresql+psycopg://github_rag:github_rag@postgres:5432/github_rag

# Exact code index (T10)
ZOEKT_URL=http://zoekt:6070
ZOEKT_INDEX_DIR=/data/index

# Vector store (T13)
QDRANT_URL=http://qdrant:6333

# SLM / embeddings (T12/T13) — OpenAI-compatible
OPENAI_BASE_URL=http://slm:11434/v1
OPENAI_API_KEY=local
SLM_MODEL=qwen2.5-coder:3b
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768

# Surfaces (T18/T17/T19)
UI_HOST=0.0.0.0
UI_PORT=8080
MCP_PORT=8001
MCP_TRANSPORT=sse

# Host mounts for compose (paths on the Docker host)
HOST_CONFIG=./examples/config.json
HOST_REPOS=./repos
